{
  "compilerOptions": {
    "target": "esnext",
    "module": "es2015",
    "lib": ["es2019", "es2020.bigint", "es2020.promise", "es2021.promise", "es2021.string", "es2022.array"],
    "allowJs": true,
    "jsx": "react-native",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
